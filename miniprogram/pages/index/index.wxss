page {
  height: 100vh;
  overflow: hidden;
  background: radial-gradient(circle at top left, rgba(199, 52, 38, 0.18), transparent 28%), linear-gradient(180deg, #fbf5ec 0%, #f2e6d7 48%, #efe4d5 100%);
  color: #1d1a16;
}

.page-root {
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.page-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.page-shell {
  padding: 24rpx 22rpx calc(188rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-card,
.panel,
.preview-shell {
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 18rpx 48rpx rgba(84, 43, 18, 0.08);
}

.hero-card {
  padding: 28rpx 28rpx 26rpx;
  background: linear-gradient(135deg, #7e231c 0%, #bf5c33 58%, #e8b269 100%);
  color: #fff7ef;
}

.hero-kicker {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  opacity: 0.78;
}

.hero-title {
  margin-top: 14rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.18;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.6;
  opacity: 0.92;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.hero-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 21rpx;
}

.panel {
  padding: 24rpx 20rpx;
  background: rgba(255, 250, 244, 0.96);
  border: 1rpx solid rgba(141, 84, 44, 0.08);
}

.panel-head {
  margin-bottom: 16rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5b1f16;
}

.panel-note {
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: #8b6b56;
}

.two-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.field-card,
.party-card,
.line-card {
  padding: 16rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(162, 120, 72, 0.12);
}

.field-label,
.party-title,
.line-card-title,
.preview-caption {
  font-size: 22rpx;
  color: #93643a;
}

.party-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.picker-tag {
  min-height: 42rpx;
  min-width: 148rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f6e8d4;
  color: #8f5a32;
  font-size: 19rpx;
  display: flex;
  align-items: center;
}

.field-input,
.field-textarea,
.picker-value {
  width: 100%;
  min-height: 72rpx;
  margin-top: 8rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #f7f2ea;
  border: 1rpx solid #eadfce;
  font-size: 27rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker-compact {
  min-height: 68rpx;
  padding-right: 60rpx;
}

.party-form-grid {
  display: grid;
  gap: 8rpx;
}

.field-textarea {
  height: 160rpx;
  padding: 18rpx 22rpx;
}

.party-stack,
.line-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.compact-stack .party-card {
  padding: 14rpx;
}

.tight-input {
  min-height: 64rpx;
  margin-top: 6rpx;
  font-size: 25rpx;
}

.helper-text {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9a6847;
}

.line-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.line-card {
  padding-top: 16rpx;
}

.add-line-button {
  margin-top: 16rpx;
  min-height: 76rpx;
  border-radius: 20rpx;
  background: #f3e3cf;
  color: #7c2a20;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 25rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.add-line-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #b94a32;
  color: #fffaf3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
}

.add-line-button:active {
  transform: scale(0.99);
  opacity: 0.9;
}

.line-metrics {
  display: flex;
  margin-top: 14rpx;
  gap: 14rpx;
  flex-wrap: wrap;
}

.metric-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f3eadb;
  color: #6f4f2e;
  font-size: 20rpx;
}

button {
  border: 0;
  border-radius: 22rpx;
  font-size: 28rpx;
  line-height: 1;
  width: 100%;
  margin: 0;
  padding-left: 0;
  padding-right: 0;
  box-sizing: border-box;
}

button::after {
  border: 0;
}

.primary-button,
.secondary-button,
.ghost-button {
  min-height: 84rpx;
}

.primary-button {
  background: linear-gradient(135deg, #8f241d 0%, #bf5a31 100%);
  color: #fff9f1;
}

.secondary-button {
  background: #f0e1cd;
  color: #6f4022;
}

.ghost-button {
  background: transparent;
  color: #8f241d;
  border: 2rpx dashed rgba(143, 36, 29, 0.3);
}

.line-delete-btn {
  min-width: auto;
  min-height: auto;
  padding: 6rpx 10rpx;
  margin: 0;
  line-height: 1.2;
  border-radius: 10rpx;
  background: transparent;
  border: 0;
  color: #c36a5f;
  font-size: 20rpx;
}

.line-delete-btn::after {
  border: 0;
}

.line-delete-btn:active {
  background: rgba(195, 106, 95, 0.08);
}

.action-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  width: 100%;
  overflow: hidden;
  box-sizing: border-box;
}

.action-button {
  flex: 1 1 0;
  min-width: 0;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-weight: 700;
}

.action-top-grid {
  align-items: stretch;
  grid-template-columns: 1.05fr 0.95fr;
}

.action-top-grid .field-input,
.action-top-grid .secondary-button {
  margin-top: 0;
}

.action-top-grid .secondary-button {
  min-height: 64rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.history-button {
  width: 100%;
  min-width: 0;
  font-weight: 700;
}

.tap-hover {
  transform: scale(0.985);
  opacity: 0.9;
}

.panel .secondary-button,
.panel .primary-button,
.panel .ghost-button {
  border-radius: 18rpx;
  font-size: 24rpx;
}

.panel .ghost-button {
  border-style: solid;
  border-width: 2rpx;
  background: #fffaf5;
}

.toast-card {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(143, 36, 29, 0.08);
  color: #8f241d;
  font-size: 24rpx;
}

.preview-shell {
  padding: 16rpx;
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.72), rgba(255, 248, 238, 0.98));
  border: 1rpx solid rgba(156, 114, 82, 0.14);
}

.preview-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin: 2rpx 6rpx 14rpx;
}

.preview-label {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #9a6b49;
}

.preview-note {
  font-size: 20rpx;
  color: #a67a58;
}

.invoice-card {
  padding: 20rpx 16rpx;
  border-radius: 18rpx;
  background: #fffdf9;
  border: 2rpx solid #d4b798;
}

.invoice-topbar {
  display: grid;
  grid-template-columns: 110rpx minmax(0, 1fr) 170rpx;
  gap: 12rpx;
  align-items: start;
}

.qr-canvas {
  width: 104rpx;
  height: 104rpx;
  border-radius: 8rpx;
  background: #ffffff;
  border: 1rpx solid #e4d2bb;
}

.invoice-title-wrap {
  flex: 1;
  text-align: center;
  min-width: 0;
}

.invoice-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #8e2018;
  line-height: 1.24;
  word-break: keep-all;
}

.invoice-rule {
  width: 96rpx;
  height: 4rpx;
  margin: 6rpx auto 10rpx;
  border-radius: 999rpx;
  background: #c74c35;
}

.seal {
  padding: 4rpx 8rpx;
  display: inline-flex;
  border-radius: 999rpx;
  border: 2rpx solid rgba(143, 36, 29, 0.28);
  color: #8f241d;
  font-size: 14rpx;
  line-height: 1.3;
}

.seal-small {
  margin-left: 6rpx;
  font-size: 12rpx;
}

.invoice-meta {
  width: 170rpx;
  font-size: 14rpx;
  color: #6f5644;
  line-height: 1.45;
}

.meta-item {
  text-align: right;
  word-break: break-all;
}

.invoice-party-table {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 60rpx minmax(0, 1fr) 60rpx minmax(0, 1fr);
  border: 1rpx solid #d9c3a7;
  border-bottom: 0;
  font-size: 16rpx;
  color: #4f4035;
}

.party-label-cell,
.party-content-cell {
  min-height: 124rpx;
  padding: 12rpx 8rpx;
  border-right: 1rpx solid #d9c3a7;
  border-bottom: 1rpx solid #d9c3a7;
  box-sizing: border-box;
}

.party-label-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #faf3ea;
  color: #7f5e47;
  font-size: 16rpx;
  line-height: 1.4;
  text-align: center;
}

.party-content-cell {
  line-height: 1.55;
  word-break: break-all;
}

.caption-text {
  color: #8f725d;
}

.goods-table {
  margin-top: 18rpx;
  border: 1rpx solid #d9c3a7;
}

.invoice-grid {
  display: grid;
  grid-template-columns: 2.2fr 0.9fr 0.9fr 1.2fr 1.2fr 1fr 1.1fr;
  align-items: center;
  font-size: 18rpx;
}

.goods-head {
  min-height: 72rpx;
  padding: 0 12rpx;
  background: #f7eee3;
  color: #6f5644;
  font-weight: 700;
  border-bottom: 1rpx solid #d9c3a7;
}

.goods-row {
  min-height: 62rpx;
  padding: 0 12rpx;
  background: #fffdfa;
  color: #4f4035;
  border-bottom: 1rpx solid #efe4d6;
}

.goods-row.is-empty {
  color: transparent;
}

.goods-total-row {
  min-height: 68rpx;
  padding: 0 12rpx;
  color: #7d2a21;
  background: #fcf5ea;
  font-size: 20rpx;
  font-weight: 700;
}

.goods-total-merge {
  grid-column: 1/5;
  text-align: center;
  letter-spacing: 12rpx;
}

.amount-table {
  margin-top: 18rpx;
  border: 1rpx solid #d9c3a7;
}

.amount-row,
.remark-row {
  display: flex;
  align-items: center;
  min-height: 76rpx;
  padding: 0 14rpx;
  font-size: 24rpx;
  color: #5d4a3c;
}

.amount-row {
  border-bottom: 1rpx solid #d9c3a7;
}

.amount-label {
  width: 168rpx;
  color: #7f5e47;
}

.amount-upper {
  flex: 1;
  font-size: 24rpx;
  color: #5d4a3c;
}

.amount-small {
  width: 220rpx;
  text-align: right;
  color: #8a231b;
  font-weight: 700;
}

.remark-label {
  width: 90rpx;
  color: #7f5e47;
}

.remark-inline-content {
  flex: 1;
  white-space: pre-wrap;
  line-height: 1.6;
}

.invoice-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 0 6rpx;
  font-size: 24rpx;
  color: #7a5d49;
}

.bottom-spacer {
  height: 148rpx;
}

.floating-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 14rpx 22rpx calc(14rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1.12fr 0.88fr;
  gap: 16rpx;
  background: linear-gradient(180deg, rgba(251, 245, 236, 0), rgba(251, 245, 236, 0.95) 22%, rgba(251, 245, 236, 0.98) 100%);
  backdrop-filter: blur(8px);
}

.floating-primary-button,
.floating-secondary-button {
  min-height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  box-sizing: border-box;
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.floating-primary-button {
  background: linear-gradient(135deg, #8f241d 0%, #bf5a31 100%);
  color: #fff9f1;
}

.floating-secondary-button {
  background: #fffaf5;
  color: #8f241d;
  border: 2rpx solid rgba(143, 36, 29, 0.18);
}

.floating-primary-button:active,
.floating-secondary-button:active,
.secondary-button:active,
.ghost-button:active {
  transform: scale(0.985);
  opacity: 0.92;
}

.export-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750px;
  height: 1180px;
  opacity: 0;
  pointer-events: none;
}